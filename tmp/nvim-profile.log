                              let groups = substitute(groups, s:notslash .. '\zs:\{2,}', ':', 'g')
                              let parsed = ""
                              while groups =~ '[^,:]'
                                let i = matchend(groups, s:notslash .. ':')
                                let j = matchend(groups, s:notslash .. ',')
