    1              0.000001 fun! s:Wholematch(string, pat, start)
                              let group = '\%(' .. a:pat .. '\)'
                              let prefix = (a:start ? '\(^.*\%<' .. (a:start + 2) .. 'c\)\zs' : '^')
                              let len = strlen(a:string)
                              let suffix = (a:start+1 < len ? '\(\%>' .. (a:start+1) .. 'c.*$\)\@=' : '$')
                              if a:string !~ prefix .. group .. suffix
