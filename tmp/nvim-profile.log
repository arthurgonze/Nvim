                              let i = matchend(tail, s:notslash .. a:comma)
                              if a:0
                                let alttail = (a:1 =~ a:comma .. "$" ? a:1 : a:1 .. a:comma)
                                let j = matchend(alttail, s:notslash .. a:comma)
                              endif
